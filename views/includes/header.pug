      p#login-info
    .header-center
      a#homeLink.brand(href='/')
        div
          img#logo-img(src='img/1-logo.png' alt='fashion market logo')
    .nav-actions
      // icorn is from https://home.streamlinehq.com/
      // free to use but need direct link
      a#searchLink.nav-tools(href='#')
        #searchInput.search-btn
          img#search-img(src='img/1-search.png' alt='search icon')

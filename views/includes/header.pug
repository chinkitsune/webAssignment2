        #loginBtn.login-btn
          img#user-img(src='img/1-user.png' alt='user icon')
      a#userLink.nav-tools(href='#')
        #cartToggle.cart-btn
          img#cart-img(src='img/1-shoppingbag.png' alt='shopping bag icon')
